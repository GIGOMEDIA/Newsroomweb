{
  "name": "crednews",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "pnpm desktop:icon && expo export --platform web",
    "web:preview": "pnpm build:web && npx --yes serve dist -p 4173 -s",
    "desktop:icon": "node desktop/scripts/build-icon.cjs",
    "desktop:dev": "concurrently \"pnpm web\" \"wait-on http://localhost:8081 && electron desktop/main.cjs\"",
    "desktop:pack": "pnpm desktop:icon && pnpm build:web && electron-builder --config electron-builder.yml",
    "desktop:win": "pnpm desktop:icon && pnpm build:web && electron-builder --config electron-builder.yml --win --dir",
    "desktop:installer": "pnpm desktop:icon && pnpm build:web && electron-builder --config electron-builder.yml --win nsis",
    "desktop:portable": "pnpm desktop:icon && pnpm build:web && electron-builder --config electron-builder.yml --win portable",
    "desktop:zip": "pnpm desktop:icon && pnpm build:web && electron-builder --config electron-builder.yml --win zip",
    "desktop:release": "pnpm desktop:icon && pnpm build:web && electron-builder --config electron-builder.yml --win",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.3.1",
    "@tanstack/query-async-storage-persister": "^5.100.5",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-query-persist-client": "^5.100.5",
    "dotenv": "^17.4.2",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-blur": "^55.0.14",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^55.0.13",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.12.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "rn-swiftauth-sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.5"
  },
  "private": true
}
